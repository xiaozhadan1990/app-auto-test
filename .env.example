APPIUM_SERVER_URL=http://127.0.0.1:4723
APPIUM_AUTOMATION_NAME=UiAutomator2
APPIUM_DEVICE_NAME=Android Device
APPIUM_UDID=
APPIUM_NO_RESET=true
APPIUM_NEW_COMMAND_TIMEOUT=240

# Desktop Web UI server
DESKTOP_WEB_HOST=127.0.0.1
DESKTOP_WEB_PORT=17999
# true: 端口占用时自动换可用端口；false: 固定使用上面的端口
DESKTOP_WEB_AUTO_PORT_FALLBACK=false

# Remote control websocket (optional)
REMOTE_WS_ENABLED=false
REMOTE_WS_URL=ws://127.0.0.1:8080/api/v1/ws/client
REMOTE_WS_CLIENT_ID=
REMOTE_WS_HEARTBEAT_SEC=15
REMOTE_WS_RECONNECT_SEC=5
REMOTE_WS_PING_INTERVAL_SEC=20
REMOTE_WS_PING_TIMEOUT_SEC=10
# 可选：当服务端无法通过 DESKTOP_WEB_HOST 访问客户端时，手动指定客户端对外访问地址
REMOTE_WS_PUBLIC_BASE_URL=

# Ruijie Cloud Android app capabilities (按实际环境修改)
RUIJIECLOUD_APP_PACKAGE=cn.com.ruijie.cloudapp
RUIJIECLOUD_APP_ACTIVITY=

# Backward compatibility (optional)
REEYEE_APP_PACKAGE=cn.com.ruijie.cloudapp
REEYEE_APP_ACTIVITY=

# Lysora Android app package
LYSORA_APP_PACKAGE=com.lysora.lyapp
